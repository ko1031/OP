# ─────────────────────────────────────────────────────────────────────────
# .env.example — 環境変数テンプレート
#
# 使い方:
#   cp .env.example .env.local
#   .env.local を編集してローカル/本番環境に合わせる
# ─────────────────────────────────────────────────────────────────────────

# PartyKit ホスト（WebSocket サーバーのアドレス）
#
# ローカル開発時（npm run party:dev で起動）:
#   VITE_PARTYKIT_HOST=localhost:1999
#
# 本番（npm run party:deploy でデプロイ後）:
#   VITE_PARTYKIT_HOST=onepiece-card-pvp.<your-username>.partykit.dev
#
VITE_PARTYKIT_HOST=onepiece-card-pvp.ko1031.partykit.dev
